---
---
<section class="hero" id="home">
  <div class="hero__text">
    <div class="hero__tag">
      <span class="dot"></span>
      Веб-разработчик · Москва · Свободен для заказов
    </div>

    <h1 class="hero__title">
      <span class="line">Сайты, после</span>
      <span class="line">которых <em>пишут</em></span>
      <span class="line">сами.</span>
    </h1>

    <p class="hero__desc">
      Продающие лендинги для экспертов — психологов, коучей, репетиторов.
      Готовлю за 1 день, без посредников, с уникальным дизайном под вашу нишу.
    </p>

    <div class="hero__actions">
      <a href="#portfolio" class="btn btn--gold" data-magnetic>Посмотреть работы</a>
      <a href="#configurator" class="btn btn--ghost">Собрать свой сайт</a>
    </div>

    <div class="hero__stats">
      <div class="stat">
        <div class="stat__n">7</div>
        <div class="stat__l">готовых<br/>кейсов</div>
      </div>
      <div class="stat">
        <div class="stat__n">1</div>
        <div class="stat__l">день<br/>на сдачу</div>
      </div>
      <div class="stat">
        <div class="stat__n">5K</div>
        <div class="stat__l">рублей<br/>старт</div>
      </div>
      <div class="stat">
        <div class="stat__n">∞</div>
        <div class="stat__l">правок<br/>неделю</div>
      </div>
    </div>
  </div>

  <!-- Live demo video / photo -->
  <div class="hero__visual reveal-right">
    <div class="hero__video-wrap">
      <!-- Placeholder for actual demo video -->
      <video
        class="hero__video"
        autoplay
        muted
        loop
        playsinline
        poster="/photo.png"
        preload="metadata"
      >
        <!-- Source will be replaced with actual screencast later -->
      </video>
      <img class="hero__photo-fallback" src="/photo.png" alt="Кирилл Барыев" />

      <div class="hero__video-overlay">
        <div class="hero__video-badge">
          <div class="rec-dot"></div>
          Живой процесс · 2:34
        </div>
        <div class="hero__video-tag">Как рождается сайт за 1 день</div>
      </div>

      <button class="hero__video-play" aria-label="Воспроизвести">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
          <path d="M8 5.14v13.72L19 12 8 5.14z"/>
        </svg>
      </button>
    </div>
  </div>
</section>

<style>
  .hero {
    min-height: 100vh;
    padding: 150px 56px 60px;
    display: grid;
    grid-template-columns: 1.15fr 1fr;
    gap: 72px;
    align-items: center;
    max-width: 1280px;
    margin: 0 auto;
    position: relative;
  }

  /* Tag */
  .hero__tag {
    display: inline-flex; align-items: center; gap: 10px;
    font-size: 11px; font-weight: 600; letter-spacing: 2.5px;
    text-transform: uppercase; color: var(--accent);
    margin-bottom: 30px;
  }
  .hero__tag .dot {
    width: 6px; height: 6px; border-radius: 50%;
    background: var(--accent);
    box-shadow: 0 0 12px var(--accent);
    animation: pulse 2s ease-in-out infinite;
  }
  @keyframes pulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.5; transform: scale(0.8); }
  }

  /* Title */
  .hero__title {
    font-size: clamp(48px, 7vw, 104px);
    font-weight: 900;
    line-height: 0.92;
    letter-spacing: -0.045em;
    margin-bottom: 32px;
  }
  .hero__title .line { display: block; }
  .hero__title em {
    font-family: 'Instrument Serif', serif;
    font-style: italic;
    font-weight: 400;
    color: var(--accent);
    padding-inline: 4px;
  }

  .hero__desc {
    font-size: 16px;
    color: var(--muted);
    line-height: 1.75;
    max-width: 440px;
    margin-bottom: 40px;
  }

  /* Buttons */
  .hero__actions { display: flex; gap: 12px; flex-wrap: wrap; margin-bottom: 56px; }
  .btn {
    padding: 15px 32px;
    border-radius: 999px;
    font-weight: 600;
    font-size: 14px;
    display: inline-flex; align-items: center; justify-content: center;
    transition: background 0.3s, border-color 0.3s, color 0.3s, box-shadow 0.3s, transform 0.2s;
  }
  .btn--gold {
    background: var(--accent);
    color: var(--bg);
    box-shadow: 0 8px 30px color-mix(in oklab, var(--accent) 30%, transparent);
  }
  .btn--gold:hover {
    box-shadow: 0 14px 50px color-mix(in oklab, var(--accent) 55%, transparent);
  }
  .btn--ghost {
    background: transparent;
    color: var(--text);
    border: 1px solid var(--border-2);
  }
  .btn--ghost:hover { border-color: var(--text); }

  /* Stats */
  .hero__stats {
    display: grid;
    grid-template-columns: repeat(4, auto);
    gap: 36px;
    align-items: center;
  }
  .stat__n {
    font-size: 38px; font-weight: 900;
    line-height: 1; letter-spacing: -0.04em;
    color: var(--text);
    font-variant-numeric: tabular-nums;
    margin-bottom: 6px;
  }
  .stat__l {
    font-size: 11px;
    color: var(--muted);
    letter-spacing: 0.5px;
    line-height: 1.4;
  }

  /* Visual (video + photo fallback) */
  .hero__visual {
    position: relative;
    aspect-ratio: 4/5;
    width: 100%;
    max-width: 460px;
    margin-left: auto;
  }
  .hero__video-wrap {
    position: relative;
    width: 100%; height: 100%;
    border-radius: 32px;
    overflow: hidden;
    border: 1px solid var(--border-2);
    background: var(--bg-card);
    box-shadow: 0 30px 80px color-mix(in oklab, var(--accent) 12%, transparent);
    transition: transform 0.5s cubic-bezier(.25,.46,.45,.94), box-shadow 0.5s;
  }
  .hero__video-wrap:hover {
    transform: translateY(-6px);
    box-shadow: 0 40px 100px color-mix(in oklab, var(--accent) 20%, transparent);
  }
  .hero__video,
  .hero__photo-fallback {
    width: 100%; height: 100%;
    object-fit: cover;
    display: block;
    filter: grayscale(15%) contrast(1.05);
    transition: filter 0.6s;
  }
  .hero__video { position: absolute; inset: 0; z-index: 1; }
  .hero__photo-fallback { position: absolute; inset: 0; z-index: 0; }
  .hero__video-wrap:hover .hero__video,
  .hero__video-wrap:hover .hero__photo-fallback {
    filter: grayscale(0%) contrast(1.1);
  }

  .hero__video-overlay {
    position: absolute;
    bottom: 0; left: 0; right: 0;
    padding: 40px 24px 24px;
    background: linear-gradient(transparent, color-mix(in oklab, var(--bg) 92%, transparent));
    z-index: 2;
  }
  .hero__video-badge {
    display: inline-flex; align-items: center; gap: 8px;
    padding: 6px 12px;
    border-radius: 999px;
    background: color-mix(in oklab, var(--bg) 65%, transparent);
    backdrop-filter: blur(12px);
    font-size: 11px; font-weight: 600;
    color: #fff;
    letter-spacing: 0.5px;
    margin-bottom: 12px;
    border: 1px solid rgba(255,255,255,0.1);
  }
  .rec-dot {
    width: 6px; height: 6px; border-radius: 50%;
    background: #e63946;
    animation: rec 1.6s ease-in-out infinite;
  }
  @keyframes rec {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.4; transform: scale(0.75); }
  }
  .hero__video-tag {
    font-size: 15px; font-weight: 600;
    color: #fff;
    letter-spacing: -0.01em;
  }

  .hero__video-play {
    position: absolute;
    top: 50%; left: 50%;
    transform: translate(-50%, -50%);
    width: 72px; height: 72px;
    border-radius: 50%;
    background: color-mix(in oklab, var(--accent) 90%, transparent);
    color: var(--bg);
    cursor: pointer;
    z-index: 3;
    display: flex; align-items: center; justify-content: center;
    transition: transform 0.3s, box-shadow 0.3s, opacity 0.4s;
    box-shadow: 0 8px 30px color-mix(in oklab, var(--accent) 45%, transparent);
    opacity: 0;
  }
  .hero__video-wrap:hover .hero__video-play { opacity: 1; }
  .hero__video-play:hover {
    transform: translate(-50%, -50%) scale(1.08);
  }
  .hero__video-play svg { margin-left: 2px; }

  /* Mobile */
  @media (max-width: 960px) {
    .hero {
      grid-template-columns: 1fr;
      padding: 110px 20px 60px;
      gap: 40px;
    }
    .hero__title { font-size: clamp(40px, 11vw, 64px); }
    .hero__actions { flex-direction: column; align-items: stretch; }
    .btn { width: 100%; }
    .hero__stats { grid-template-columns: repeat(2, 1fr); gap: 20px; }
    .stat__n { font-size: 30px; }
    .hero__visual { max-width: 340px; margin: 0 auto; }
    .hero__video-play { opacity: 1; width: 60px; height: 60px; }
  }
</style>
