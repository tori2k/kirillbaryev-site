---
import Logo from './Logo.astro';
import ThemeToggle from './ThemeToggle.astro';
---
<nav id="nav" class="nav">
  <a href="#home" class="nav__brand" aria-label="На главную">
    <Logo size={34} />
    <span class="nav__wordmark">Kirill Baryev</span>
  </a>

  <div class="nav__links">
    <a href="#about">Обо мне</a>
    <a href="#portfolio">Работы</a>
    <a href="#configurator">Конфигуратор</a>
    <a href="#faq">FAQ</a>
  </div>

  <div class="nav__right">
    <ThemeToggle />
    <a href="https://t.me/tori2k" class="nav__cta" data-magnetic target="_blank" rel="noopener">Написать</a>
    <button class="burger" id="burger" aria-label="Меню"><span></span><span></span><span></span></button>
  </div>
</nav>

<div class="mob-menu" id="mob-menu">
  <a href="#about"        data-close>Обо мне</a>
  <a href="#portfolio"    data-close>Работы</a>
  <a href="#configurator" data-close>Конфигуратор</a>
  <a href="#faq"          data-close>FAQ</a>
  <a href="https://t.me/tori2k" class="mob-cta" target="_blank" rel="noopener" data-close>Написать в Telegram</a>
</div>

<style>
  .nav {
    position: fixed; top: 0; left: 0; right: 0; z-index: 500;
    padding: 22px 40px;
    display: flex; justify-content: space-between; align-items: center;
    transition: padding 0.4s, background 0.4s, border-color 0.4s, backdrop-filter 0.4s;
  }
  .nav.scrolled {
    background: color-mix(in oklab, var(--bg) 85%, transparent);
    backdrop-filter: blur(24px);
    -webkit-backdrop-filter: blur(24px);
    border-bottom: 1px solid var(--border);
    padding: 14px 40px;
  }

  .nav__brand {
    display: flex; align-items: center; gap: 10px;
    font-weight: 700; font-size: 13px; letter-spacing: 1px;
    text-transform: uppercase;
    color: var(--text);
  }
  .nav__wordmark { transition: color 0.3s; }
  .nav__brand:hover .nav__wordmark { color: var(--accent); }

  .nav__links {
    display: flex; gap: 36px;
    position: absolute; left: 50%; transform: translateX(-50%);
  }
  .nav__links a {
    color: var(--muted);
    font-size: 13px; font-weight: 500;
    transition: color 0.3s;
  }
  .nav__links a:hover { color: var(--text); }

  .nav__right { display: flex; align-items: center; gap: 14px; }

  .nav__cta {
    font-size: 13px; font-weight: 600;
    color: var(--bg);
    background: var(--text);
    padding: 10px 22px;
    border-radius: 999px;
    transition: background 0.3s, color 0.3s, box-shadow 0.3s, transform 0.2s;
    display: inline-block;
  }
  .nav__cta:hover {
    background: var(--accent);
    color: var(--bg);
    box-shadow: 0 0 30px color-mix(in oklab, var(--accent) 45%, transparent);
  }

  .burger {
    display: none;
    flex-direction: column; gap: 5px;
    width: 36px; height: 36px;
    cursor: pointer;
    padding: 0; z-index: 600;
  }
  .burger span {
    display: block; width: 20px; height: 1.5px;
    background: var(--text); margin-inline: auto;
    transition: transform 0.35s, opacity 0.25s;
    transform-origin: center;
  }
  .burger.open span:nth-child(1) { transform: translateY(6.5px) rotate(45deg); }
  .burger.open span:nth-child(2) { opacity: 0; transform: scaleX(0); }
  .burger.open span:nth-child(3) { transform: translateY(-6.5px) rotate(-45deg); }

  .mob-menu {
    position: fixed; inset: 0; z-index: 550;
    background: color-mix(in oklab, var(--bg) 98%, transparent);
    backdrop-filter: blur(24px);
    -webkit-backdrop-filter: blur(24px);
    display: flex; flex-direction: column;
    align-items: center; justify-content: center; gap: 8px;
    opacity: 0; pointer-events: none;
    transition: opacity 0.4s;
  }
  .mob-menu.open { opacity: 1; pointer-events: all; }
  .mob-menu a {
    font-size: 36px; font-weight: 900;
    color: color-mix(in oklab, var(--text) 45%, transparent);
    letter-spacing: -0.03em;
    transform: translateY(20px);
    transition: color 0.3s, transform 0.35s;
  }
  .mob-menu.open a { transform: translateY(0); }
  .mob-menu.open a:nth-child(1) { transition-delay: .05s; }
  .mob-menu.open a:nth-child(2) { transition-delay: .10s; }
  .mob-menu.open a:nth-child(3) { transition-delay: .15s; }
  .mob-menu.open a:nth-child(4) { transition-delay: .20s; }
  .mob-menu.open a:nth-child(5) { transition-delay: .25s; }
  .mob-menu a:hover { color: var(--text); }
  .mob-cta {
    margin-top: 24px;
    font-size: 17px !important; font-weight: 700 !important;
    color: var(--bg) !important;
    background: var(--accent);
    padding: 14px 40px;
    border-radius: 999px;
  }

  @media (max-width: 960px) {
    .nav { padding: 18px 20px; }
    .nav.scrolled { padding: 14px 20px; }
    .nav__links, .nav__cta { display: none; }
    .burger { display: flex; }
  }
</style>

<script>
  const nav = document.getElementById('nav');
  const burger = document.getElementById('burger');
  const mobMenu = document.getElementById('mob-menu');

  window.addEventListener('scroll', () => {
    nav?.classList.toggle('scrolled', window.scrollY > 60);
  }, { passive: true });

  burger?.addEventListener('click', () => {
    const open = mobMenu?.classList.toggle('open');
    burger.classList.toggle('open', !!open);
    document.body.style.overflow = open ? 'hidden' : '';
  });

  mobMenu?.querySelectorAll('[data-close]').forEach((el) => {
    el.addEventListener('click', () => {
      mobMenu.classList.remove('open');
      burger?.classList.remove('open');
      document.body.style.overflow = '';
    });
  });

  document.querySelectorAll('[data-magnetic]').forEach((btn) => {
    const el = btn as HTMLElement;
    el.addEventListener('mousemove', (e) => {
      const r = el.getBoundingClientRect();
      const me = e as MouseEvent;
      el.style.transform = `translate(${(me.clientX - r.left - r.width/2) * 0.28}px, ${(me.clientY - r.top - r.height/2) * 0.28}px)`;
    });
    el.addEventListener('mouseleave', () => { el.style.transform = ''; });
  });
</script>
