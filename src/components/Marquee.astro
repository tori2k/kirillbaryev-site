---
const items = [
  'Сайты для экспертов',
  'Готово за 1 день',
  'Уникальный дизайн',
  'Бесплатный хостинг',
  'Неделя правок',
  'Telegram @tori2k',
];
---
<div class="marquee-wrap">
  <div class="marquee-inner">
    {[...items, ...items, ...items].map((item, i) => (
      <>
        <span class:list={['item', i % 3 === 1 && 'accent']}>{item}</span>
        <span class="sep">✦</span>
      </>
    ))}
  </div>
</div>

<style>
  .marquee-wrap {
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
    padding: 18px 0;
    overflow: hidden;
    background: color-mix(in oklab, var(--bg-soft) 60%, transparent);
  }
  .marquee-inner {
    display: flex;
    white-space: nowrap;
    width: max-content;
    animation: marquee 42s linear infinite;
  }
  .item, .sep {
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 3px;
    text-transform: uppercase;
    padding: 0 32px;
    flex-shrink: 0;
  }
  .item { color: var(--muted-2); }
  .item.accent { color: var(--accent); }
  .sep { color: var(--accent); font-size: 10px; }

  @keyframes marquee {
    from { transform: translateX(0); }
    to { transform: translateX(-33.3333%); }
  }
</style>
