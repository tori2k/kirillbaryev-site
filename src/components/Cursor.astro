---
---
<div class="orbs" aria-hidden="true">
  <div class="orb orb1"></div>
  <div class="orb orb2"></div>
</div>
<div id="cur-dot" aria-hidden="true"></div>
<div id="cur-ring" aria-hidden="true"></div>
<div id="progress-bar" aria-hidden="true"></div>

<style>
  /* Orbs */
  .orbs { position: fixed; inset: 0; z-index: -1; overflow: hidden; pointer-events: none; }
  .orb {
    position: absolute;
    border-radius: 50%;
    background: radial-gradient(circle, color-mix(in oklab, var(--accent) 18%, transparent) 0%, transparent 65%);
    transition: background 0.6s ease;
  }
  .orb1 { width: 600px; height: 600px; top: -150px; right: -150px; animation: o1 20s ease-in-out infinite alternate; }
  .orb2 { width: 400px; height: 400px; bottom: 10%; left: -100px; animation: o2 16s ease-in-out infinite alternate; }
  @keyframes o1 { 0% { transform: translate(0,0) scale(1); } 100% { transform: translate(-80px,120px) scale(1.2); } }
  @keyframes o2 { 0% { transform: translate(0,0); } 100% { transform: translate(80px,-100px) scale(1.15); } }

  /* Cursor */
  #cur-dot {
    width: 5px; height: 5px;
    background: var(--accent);
    border-radius: 50%;
    position: fixed; top: 0; left: 0;
    pointer-events: none; z-index: 9999;
    transform: translate(-50%, -50%);
    transition: background 0.4s;
  }
  #cur-ring {
    width: 30px; height: 30px;
    border: 1px solid color-mix(in oklab, var(--accent) 50%, transparent);
    border-radius: 50%;
    position: fixed; top: 0; left: 0;
    pointer-events: none; z-index: 9998;
    transform: translate(-50%, -50%);
    transition: width .3s, height .3s, border-color .3s, background .3s;
  }
  #cur-ring.hover {
    width: 52px; height: 52px;
    background: color-mix(in oklab, var(--accent) 8%, transparent);
    border-color: var(--accent);
  }

  /* Progress bar */
  #progress-bar {
    position: fixed; top: 0; left: 0;
    height: 1.5px; z-index: 1000;
    background: var(--accent);
    width: 0%;
    transition: background 0.4s;
  }

  @media (hover: none), (pointer: coarse) {
    #cur-dot, #cur-ring { display: none; }
  }
</style>

<script>
  const dot = document.getElementById('cur-dot');
  const ring = document.getElementById('cur-ring');
  const bar = document.getElementById('progress-bar');

  if (dot && ring) {
    let mx = 0, my = 0, rx = 0, ry = 0;

    document.addEventListener('mousemove', (e) => {
      mx = e.clientX; my = e.clientY;
      dot.style.left = mx + 'px';
      dot.style.top = my + 'px';
    });

    document.addEventListener('mousedown', () => {
      ring.style.transform = 'translate(-50%,-50%) scale(0.7)';
    });
    document.addEventListener('mouseup', () => {
      ring.style.transform = 'translate(-50%,-50%)';
    });

    (function tick() {
      rx += (mx - rx) * 0.12;
      ry += (my - ry) * 0.12;
      ring.style.left = rx + 'px';
      ring.style.top = ry + 'px';
      requestAnimationFrame(tick);
    })();

    const markHoverable = () => {
      document.querySelectorAll('a, button, [data-magnetic], .case-card, .process-item').forEach((el) => {
        if ((el as any).__cursorBound) return;
        (el as any).__cursorBound = true;
        el.addEventListener('mouseenter', () => ring.classList.add('hover'));
        el.addEventListener('mouseleave', () => ring.classList.remove('hover'));
      });
    };
    markHoverable();
    new MutationObserver(markHoverable).observe(document.body, { childList: true, subtree: true });
  }

  if (bar) {
    window.addEventListener('scroll', () => {
      const scrolled = window.scrollY / (document.body.scrollHeight - window.innerHeight);
      bar.style.width = (scrolled * 100) + '%';
    }, { passive: true });
  }
</script>
